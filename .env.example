# Flask / gunicorn
APP_HOST=127.0.0.1
APP_PORT=8000
GUNICORN_WORKERS=2
CORS_ORIGINS=http://localhost:8000

# Shared environment file used by Python and PHP. Keep this outside the web root in production.
PHP_ENV_FILE=/opt/koko/.env

# Database (shared by Python and PHP)
DB_HOST=127.0.0.1
DB_PORT=13306
DB_USER=kugo
DB_PASSWORD=
DB_NAME=kugo
DB_CHARSET=utf8mb4

# SMTP / mail alerts (shared PHP mail scripts)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=change-me@qq.com
SMTP_PASSWORD=change-me
SMTP_ENCRYPTION=ssl
MAIL_FROM=change-me@qq.com
MAIL_FROM_NAME=Koko
MAIL_TO=admin@example.com
MAIL_TO_NAME=Admin

# Admin protection. Dangerous Python and PHP admin APIs reject requests when this is empty.
ADMIN_API_TOKEN=change-me

# Public API / domestic worker polling
PUBLIC_API_BASE_URL=https://your-api-domain.example.com
WORKER_API_TOKEN=change-me
WORKER_ID=worker-cn-01
WORKER_POLL_INTERVAL=3

# Logs
APP_LOG_FILE=/opt/koko/logs/all.log
USER_LOG_FILE=/opt/koko/logs/userpy.log

# Browser automation: set to 1 only on hosts with Chrome/Chromedriver installed.
AUTO_START_BROWSER_POOL=0

# Windows local image task runner (RemoteServer/img.py)
# Copy these values to RemoteServer/.env or export them as environment variables.
LSKY_API_URL=https://lsky.k2n.cn/api/v1/upload
LSKY_TOKEN=
LSKY_STRATEGY_ID=3
CAPTCHA_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
LOCAL_IMAGE_FOLDER=D:\leidian\记录\充值成功
SCREENSHOTS_FOLDER=D:\leidian\Screenshots
OCR_IMAGE_FOLDER=D:\leidian\ocr_yz
LOG_DIR=D:\leidian\auto-tool\img\test
LOCAL_API_TOKEN=
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
DB_CONNECT_TIMEOUT=10
DB_READ_TIMEOUT=30
DB_WRITE_TIMEOUT=30
