# Flask / gunicorn
APP_HOST=127.0.0.1
APP_PORT=8000
GUNICORN_WORKERS=2
CORS_ORIGINS=http://localhost:8000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=koko
DB_PASSWORD=change-me
DB_NAME=kugo
DB_CHARSET=utf8mb4

# Logs
APP_LOG_FILE=/opt/koko/logs/all.log
USER_LOG_FILE=/opt/koko/logs/userpy.log

# Browser automation: set to 1 only on hosts with Chrome/Chromedriver installed.
AUTO_START_BROWSER_POOL=0

# Optional future hardening: configure reverse proxy to add this header for admin paths.
ADMIN_API_TOKEN=change-me-after-frontend-proxy-is-configured
# PHP admin endpoints read the same env keys; PHP_ENV_FILE helps PHP-FPM find this file.
PHP_ENV_FILE=/opt/koko/.env
# SMTP / alert mail
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=change-me@qq.com
SMTP_PASSWORD=change-me
SMTP_ENCRYPTION=ssl
MAIL_FROM=change-me@qq.com
MAIL_FROM_NAME=Koko
MAIL_TO=admin@example.com
MAIL_TO_NAME=Admin
